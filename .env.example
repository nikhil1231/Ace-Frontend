# Local backend URL used by the "local" environment in Settings.
REACT_APP_BACKEND_URL_LOCAL=http://192.168.0.219:8000

# Optional hosted backend URLs.
REACT_APP_BACKEND_URL_HOSTED=https://example.com
REACT_APP_BACKEND_URL=https://example.com

# Google Maps JavaScript API key used by the map page.
REACT_APP_GOOGLE_MAPS_API=your_google_maps_api_key_here
